# Database connection
# Defaults to local SQLite file for immediate out-of-the-box operation.
# To use PostgreSQL, set this to e.g. postgresql+asyncpg://user:pass@localhost:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./alphamatrix.db

# Optional Redis connection (used for caching & task queueing in production)
# Leave blank to fall back to in-memory caching and FastAPI background tasks
REDIS_URL=redis://localhost:6379

# Groq API Key (required for AI analyst summaries & semantic query parsing)
# Get a key from Groq Console (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Security configurations
SECRET_KEY=SUPERSYSTEMATIC_SECRET_FOR_ALPHAMATRIX_LOCAL_DEMO_RUN
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
